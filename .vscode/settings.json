{
  "files.trimTrailingWhitespace": true,
  "files.eol": "\n",
  "files.associations": {
    // stop markdownlint from complaining about a plain text LICENSE file
    "LICENSE": "plaintext",
    "*.webmanifest": "jsonc",
    "*.yaml.example": "yaml"
  },
  "ruff.enable": true,
  "ruff.lint.select": ["ALL"],
  "ruff.lint.ignore": [
    "ANN", // type annotations
    "TD", // TODO
    "FIX" // TODO
  ],
  "[jsonc]": {
    "editor.formatOnSave": true,
    "editor.tabSize": 2,
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    // When opening a file, `editor.tabSize` and `editor.insertSpaces`
    // will be detected based on the file contents. Set to false to keep
    // the values you've explicitly set, above.
    // https://stackoverflow.com/a/29972553
    "editor.detectIndentation": false
  },
  "[javascript]": {
    "editor.formatOnSave": true,
    "editor.tabSize": 2,
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[css]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "vscode.css-language-features"
  },
  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.organizeImports": "explicit"
    }
  },
  "[html]": {
    "editor.defaultFormatter": "vscode.html-language-features",
    "editor.formatOnSave": true
  },
  "workbench.colorCustomizations": {
    "activityBar.activeBackground": "#231b39",
    "activityBar.background": "#231b39",
    "activityBar.foreground": "#e7e7e7",
    "activityBar.inactiveForeground": "#e7e7e799",
    "activityBarBadge.background": "#82503d",
    "activityBarBadge.foreground": "#e7e7e7",
    "commandCenter.border": "#e7e7e799",
    "sash.hoverBorder": "#231b39",
    "statusBar.background": "#0e0b17",
    "statusBar.foreground": "#e7e7e7",
    "statusBarItem.hoverBackground": "#231b39",
    "statusBarItem.remoteBackground": "#0e0b17",
    "statusBarItem.remoteForeground": "#e7e7e7",
    "titleBar.activeBackground": "#0e0b17",
    "titleBar.activeForeground": "#e7e7e7",
    "titleBar.inactiveBackground": "#0e0b1799",
    "titleBar.inactiveForeground": "#e7e7e799"
  },
  "peacock.color": "#0E0B17"
}
